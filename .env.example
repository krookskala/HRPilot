# ──────────────────────────────────────────
# HRPilot Environment Variables
# Copy to .env and fill in production values
# ──────────────────────────────────────────

# PostgreSQL
POSTGRES_DB=hrpilot
POSTGRES_USER=hrpilot
POSTGRES_PASSWORD=change-me-strong-password

# JWT — MUST be at least 256 bits (32+ chars)
JWT_SECRET=change-me-generate-a-secure-random-key-at-least-256-bits

# Spring Profile (dev | prod)
SPRING_PROFILES_ACTIVE=prod

# File Storage (local | s3)
APP_STORAGE_PROVIDER=local
APP_STORAGE_LOCAL_UPLOAD_DIR=/app/uploads

# S3 (only if APP_STORAGE_PROVIDER=s3)
APP_STORAGE_S3_BUCKET=
APP_STORAGE_S3_REGION=
APP_STORAGE_S3_ENDPOINT=
APP_STORAGE_S3_ACCESS_KEY=
APP_STORAGE_S3_SECRET_KEY=

# Frontend
APP_FRONTEND_BASE_URL=http://localhost:4200
